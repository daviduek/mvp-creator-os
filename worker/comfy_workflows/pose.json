{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" }
  },
  "10": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "sashavan.safetensors",
      "strength_model": 0.85,
      "strength_clip": 0.85,
      "model": ["1", 0],
      "clip": ["1", 1]
    }
  },
  "20": {
    "class_type": "LoadImage",
    "inputs": { "image": "pose.png" }
  },
  "21": {
    "class_type": "OpenposePreprocessor",
    "inputs": {
      "image": ["20", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 1024
    }
  },
  "23": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "controlnet-openpose-sdxl.safetensors" }
  },
  "22": {
    "class_type": "ControlNetApply",
    "inputs": {
      "strength": 0.9,
      "conditioning": ["6", 0],
      "control_net": ["23", 0],
      "image": ["21", 0]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "", "clip": ["10", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "lowres, blurry", "clip": ["10", 1] }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": 1024, "height": 1024, "batch_size": 1 }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": -1,
      "steps": 30,
      "cfg": 7,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["10", 0],
      "positive": ["22", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["1", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "sasha_pose", "images": ["8", 0] }
  }
}
